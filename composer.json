{
  "name": "starisian-technologies/sparxstar-boson-scaffold",
  "description": "SPARXSTAR Boson Scaffold — a WordPress Multisite MU-plugin scaffold. Rename this when building your own project.",
  "type": "wordpress-muplugin",
  "license": "MIT",
  "authors": [
    {
      "name": "Starisian Technologies",
      "email": "info@starisian.tech"
    }
  ],
  "require": {
    "php": ">=8.2",
    "composer/installers": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "automattic/vipwpcs": "^3.0",
    "phpcompatibility/php-compatibility": "^9.3",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpstan/phpstan": "^1.12",
    "phpstan/extension-installer": "^1.4",
    "szepeviktor/phpstan-wordpress": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "Starisian\\Sparxstar\\BosonScaffold\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Starisian\\Sparxstar\\BosonScaffold\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "phpcs",
    "lint:fix": "phpcbf",
    "phpstan": "phpstan analyse --level=5",
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html coverage"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    }
  }
}
