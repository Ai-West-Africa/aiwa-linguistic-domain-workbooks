{
  "name": "sparxstar-boson-scaffold",
  "version": "1.0.0",
  "description": "SPARXSTAR Boson Scaffold — Node.js dev tooling (ESLint, Stylelint, markdownlint, HTMLHint, JSON lint).",
  "private": true,
  "scripts": {
    "lint:js": "eslint '**/*.js' --ignore-path .eslintignore",
    "lint:css": "stylelint '**/*.{css,scss}' --ignore-path .stylelintignore",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules --ignore vendor",
    "lint:md:workbooks": "markdownlint 'workbooks/**/*.md'",
    "build:workbooks": "bash scripts/export-workbooks.sh",
    "lint:html": "htmlhint '**/*.html' --ignore-path .htmlhintignore",
    "lint:json": "node -e \"const fs=require('fs'),g=require('glob');g.sync('**/*.json',{ignore:['node_modules/**','vendor/**','composer.lock']}).forEach(f=>{try{JSON.parse(fs.readFileSync(f,'utf8'))}catch(e){console.error(f+': '+e.message);process.exit(1)}});console.log('All JSON files valid.')\"",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:md && npm run lint:html && npm run lint:json"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "markdownlint-cli": "^0.43.0",
    "htmlhint": "^1.1.4",
    "glob": "^11.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
