{
  "extends": ["stylelint-config-standard"],
  "ignoreFiles": [
    "node_modules/**",
    "vendor/**",
    "coverage/**",
    "dist/**",
    "build/**"
  ],
  "rules": {
    "color-no-invalid-hex": true,
    "unit-no-unknown": true,
    "property-no-unknown": true,
    "selector-class-pattern": "^[a-z][a-z0-9\\-]*$",
    "no-duplicate-selectors": true
  }
}
